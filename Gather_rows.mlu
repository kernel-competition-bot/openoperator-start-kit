#warning "BUILD_VERSION v110_50_probe_Pa_empty_only"

#include <torch/extension.h>
#include <stdint.h>

#define BATCH 64
#define K_COL 32

torch::Tensor bang_func(torch::Tensor input,
                        torch::Tensor index) {
    // 不 launch kernel
    // 只测 torch::empty + wrapper dispatch + evaluator sync
    return torch::empty({BATCH, K_COL}, input.options());
}